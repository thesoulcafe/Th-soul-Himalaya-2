{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A booking for a tour, trek, or stay.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who made the booking." },
        "userName": { "type": "string", "description": "Full name of the guest." },
        "userEmail": { "type": "string", "format": "email", "description": "Email of the guest." },
        "serviceType": { "type": "string", "enum": ["tour", "trek", "wfh", "yoga", "meditation", "adventure", "shop"], "description": "The type of service booked." },
        "serviceName": { "type": "string", "description": "The specific name of the package." },
        "date": { "type": "string", "format": "date", "description": "The start date of the booking." },
        "guests": { "type": "number", "description": "Number of people." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Current status of the booking." },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"], "description": "Status of the payment." },
        "totalPrice": { "type": "number", "description": "Total amount in INR." },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "pincode": { "type": "string" },
        "razorpayOrderId": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "price": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created." }
      },
      "required": ["userId", "userName", "userEmail", "serviceType", "serviceName", "date", "guests", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Private profile data for a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role for RBAC." },
        "loyaltyPoints": { "type": "number", "description": "Points earned for repeat visits." },
        "soulPoints": { "type": "number", "description": "Points for the multiplayer leaderboard." },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time", "description": "Last time the user was active." },
        "trekPreferences": {
          "type": "object",
          "properties": {
            "difficulty": { "type": "string", "enum": ["easy", "moderate", "challenging", "extreme"] },
            "preferredMonths": { "type": "array", "items": { "type": "string" } },
            "groupSize": { "type": "string", "enum": ["solo", "couple", "group"] },
            "interests": { "type": "array", "items": { "type": "string" } }
          }
        },
        "wishlist": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of Content IDs in the user's wishlist."
        },
        "experienceLevel": { 
          "type": "string", 
          "enum": ["novice", "intermediate", "expert"],
          "description": "User's self-reported Himalayan experience level."
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a service.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number", "description": "Rating from 1 to 5." },
        "comment": { "type": "string" },
        "serviceId": { "type": "string", "description": "ID of the service being reviewed." },
        "serviceType": { "type": "string", "description": "Type of service (tour, trek, etc.)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "serviceId", "serviceType", "createdAt"]
    },
    "Content": {
      "title": "Content",
      "description": "Website content items like tours, treks, and services.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["tour", "trek", "shop_item", "service", "yoga", "meditation", "adventure", "wfh", "page_parvati"] },
        "data": { 
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "price": { "type": "string" },
            "image": { "type": "string" },
            "description": { "type": "string" },
            "duration": { "type": "string" },
            "isBestSeller": { "type": "boolean" },
            "isAvailable": { "type": "boolean", "description": "Whether the service is currently available." },
            "order": { "type": "number", "description": "Display order of the item." },
            "theme": { "type": "string" },
            "link": { "type": "string" },
            "slots": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "startDate": { "type": "string", "format": "date" },
                  "endDate": { "type": "string", "format": "date" },
                  "available": { "type": "boolean" }
                }
              }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "data"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct message from a user to the admin.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the sender (optional for guests)." },
        "userName": { "type": "string", "description": "Full name of the sender." },
        "userEmail": { "type": "string", "format": "email", "description": "Email of the sender." },
        "subject": { "type": "string", "description": "Subject of the message." },
        "message": { "type": "string", "description": "The message content." },
        "status": { "type": "string", "enum": ["unread", "read", "replied"], "description": "Status of the message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["userName", "userEmail", "subject", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all service bookings."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile documents."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of all customer reviews."
    },
    "/content/{contentId}": {
      "schema": "Content",
      "description": "Collection of dynamic website content."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages from users to admin."
    },
    "/seo_settings/{settingId}": {
      "schema": "object",
      "description": "Page-specific SEO configurations."
    },
    "/site_settings/global": {
      "schema": "object",
      "description": "Global website settings like verification tokens."
    }
  }
}
